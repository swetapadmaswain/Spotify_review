# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/spotify_reviews
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spotify_reviews
DB_USER=user
DB_PASSWORD=password

# App Store Configuration
APP_STORE_APP_ID=324684580
APP_STORE_API_KEY=your_app_store_api_key

# Play Store Configuration
PLAY_STORE_PACKAGE_NAME=com.spotify.music

# Reddit Configuration
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SpotifyReviewAnalysis/1.0

# Twitter Configuration
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Facebook Configuration
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# S3/MinIO Configuration
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=spotify-reviews-raw
S3_REGION=us-east-1

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Data Collection Settings
REVIEWS_LIMIT=500
BATCH_SIZE=500

# Phase 4: Reporting & Dashboard
API_AUTH_TOKEN=your_api_auth_token_optional
REPORTS_OUTPUT_DIR=./reports

# Open API Key
OPENAI_API_KEY=your_openai_api_key
