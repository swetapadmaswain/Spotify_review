{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "dist",
  "installCommand": "pip install -r requirements.txt",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/vercel.py"
    },
    {
      "source": "/(.*)",
      "destination": "/vercel.py"
    }
  ]
}
